generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Cada imobiliária = uma Conta (tenant). Todo dado pertence a uma Conta.
model Conta {
  id        String    @id @default(cuid())
  nome      String // nome da imobiliária
  plano     String    @default("trial") // trial, pessoal, empresarial (base p/ Asaas)
  status    String    @default("ativo") // ativo, suspenso (base p/ Asaas)
  criadoEm  DateTime  @default(now())
  usuarios  Usuario[]
  imoveis   Imovel[]
  anuncios  Anuncio[]
  clientes  Cliente[]
  carteira  Carteira?
}

model Usuario {
  id        String   @id @default(cuid())
  conta     Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contaId   String
  nome      String
  email     String   @unique
  senhaHash String
  papel     String   @default("admin") // admin (dono) | corretor
  criadoEm  DateTime @default(now())

  @@index([contaId])
}

model Imovel {
  id          String    @id @default(cuid())
  conta       Conta     @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contaId     String
  titulo      String
  tipo        String    // apartamento, casa, terreno, comercial...
  finalidade  String    @default("venda") // venda ou aluguel
  bairro      String
  cidade      String
  quartos     Int       @default(0)
  banheiros   Int       @default(0)
  vagas       Int       @default(0)
  area        Float     @default(0) // m2
  preco       Float     @default(0)
  descricao   String    @default("")
  criadoEm    DateTime  @default(now())
  anuncios    Anuncio[]

  @@index([contaId])
}

model Anuncio {
  id        String   @id @default(cuid())
  conta     Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contaId   String
  canal     String   // instagram, whatsapp, portal
  conteudo  String
  imovel    Imovel   @relation(fields: [imovelId], references: [id], onDelete: Cascade)
  imovelId  String
  criadoEm  DateTime @default(now())

  @@index([contaId])
}

model Cliente {
  id         String   @id @default(cuid())
  conta      Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contaId    String
  nome       String
  telefone   String   @default("")
  email      String   @default("")
  instagram  String   @default("")
  etapa      String   @default("Novo") // Novo, Contato, Visita, Proposta, Fechado
  interesse  String   @default("") // o que procura / imóvel de interesse
  observacao String   @default("") // anotações
  historico  String   @default("") // JSON: [{data, texto}] histórico de contatos
  criadoEm   DateTime @default(now())
  atualizado DateTime @updatedAt

  @@index([contaId])
}

// Carteira agora guarda: uso no mês, bônus da roleta e vídeos (recurso à parte).
// Limite final por recurso = base do plano + bônus. Ver lib/limites.ts.
model Carteira {
  id                 String    @id @default(cuid())
  conta              Conta     @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contaId            String    @unique

  // uso no mês (reseta no primeiro giro de um novo mês)
  descricoesUsadas   Int       @default(0)
  interacoesUsadas   Int       @default(0)
  cicloMes           Int       @default(0) // 1-12, mês do ciclo atual (0 = ainda não iniciado)
  cicloAno           Int       @default(0)

  // bônus da roleta que se somam ao limite base do mês
  bonusDescricoes    Int       @default(0)
  bonusInteracoes    Int       @default(0)

  // vídeos são créditos separados (recurso especial, não tem limite mensal)
  videos             Int       @default(0)

  ultimoGiro         DateTime?
}
